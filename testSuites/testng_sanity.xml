<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Sanity Suite">

	<groups>
		<run>
			<include name="sanity" />
		</run>
	</groups>

	<listeners>
		<listener class-name="seleniumFramework.listeners.Listeners" />
	</listeners>

	<test name="Sanity Tests">
		<classes>
			<class name="seleniumFramework.tests.LoginTest" />
			<class name="seleniumFramework.tests.ProductTest" />
			<class name="seleniumFramework.tests.CartTest" />

		</classes>
	</test>
</suite>
