<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite parallel="tests" name="Regression Suite">
	<listeners>
		<listener class-name="seleniumFramework.listeners.Listeners" />
	</listeners>
	<test name="Login Test">
		<classes>
			<class name="seleniumFramework.tests.LoginTest" />
			
		</classes>
	</test>
	<test name="Product Test">
		<classes>
			<class name="seleniumFramework.tests.ProductTest" />

		</classes>
	</test>
	<test name="Cart Test">
		<classes>
			<class name="seleniumFramework.tests.CartTest" />
			
		</classes>
	</test>
	<test name="Checkout Test">
		<classes>
			<class name="seleniumFramework.tests.CheckoutTest" />

		</classes>
	</test>
	<test name="Payment Test">
		<classes>
			<class name="seleniumFramework.tests.PaymentTest" />
			
		</classes>
	</test>
</suite> 
